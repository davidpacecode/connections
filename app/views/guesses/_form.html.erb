<%= form_with(model: guess) do |form| %>
  <% if guess.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(guess.errors.count, "error") %> prohibited this guess from being saved:</h2>

      <ul>
        <% guess.errors.each do |error| %>
          <li><%= error.full_message %></li>
