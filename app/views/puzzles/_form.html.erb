<%= form_with(model: puzzle) do |form| %>
  <% if puzzle.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(puzzle.errors.count, "error") %> prohibited this puzzle from being saved:</h2>

      <ul>
        <% puzzle.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :puzzle_number, style: "display: block" %>
    <%= form.number_field :puzzle_number %>
  </div>

  <div>
    <%= form.label :published_on, style: "display: block" %>
    <%= form.date_field :published_on %>
  </div>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :submitted_by, style: "display: block" %>
    <%= form.text_field :submitted_by %>
  </div>

  <div>
    <%= form.label :hint, style: "display: block" %>
    <%= form.rich_text_area :hint %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
