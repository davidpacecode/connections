<%= form_with(model: [@puzzle, grouping], id: "edit_#{@puzzle.id}_#{grouping.id}", style: "display: none;") do |form| %>
  <% if grouping.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(grouping.errors.count, "error") %> prohibited this grouping from being saved:</h2>

      <ul>
        <% grouping.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
<% end %>

<span><%= select_tag :color, Grouping.colors.keys.map { |color| [color.capitalize, color] }, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<span><%= text_field_tag :common_thread, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<span><%= text_field_tag :word_1, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<span><%= text_field_tag :word_2, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<span><%= text_field_tag :word_3, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<span><%= text_field_tag :word_4, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<div>
  <%= submit_tag form: "edit_#{@puzzle.id}_#{grouping.id}" %>
  <wa-button href="<%= puzzle_path(@puzzle) %>" form="<%= "edit_#{@puzzle.id}_#{grouping.id}" %>">Nevermind</wa-button>
</div>
