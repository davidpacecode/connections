<wa-badge style="font-size: var(--wa-font-size-s); background-color: var(--wa-color-<%= grouping.color %>-90);">
  <%= grouping.color.titleize %></wa-badge>
<span><%= text_field_tag "grouping[common_thread]", grouping.common_thread, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<span><%= text_field_tag "grouping[word_1]", grouping.word_1, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<span><%= text_field_tag "grouping[word_2]", grouping.word_2, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<span><%= text_field_tag "grouping[word_3]", grouping.word_3, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<span><%= text_field_tag "grouping[word_4]", grouping.word_4, form: "edit_#{@puzzle.id}_#{grouping.id}" %></span>
<div>
  <%= submit_tag "Submit", form: "edit_#{@puzzle.id}_#{grouping.id}" %>
  <wa-button href="<%= puzzle_path(@puzzle) %>" form="<%= "edit_#{@puzzle.id}_#{grouping.id}" %>">Nevermind</wa-button>
</div>

<%= form_with(model: [@puzzle, grouping], id: "edit_#{@puzzle.id}_#{grouping.id}", style: "display: none;") do |form| %>
  <% if grouping.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(grouping.errors.count, "error") %> prohibited this grouping from being saved:</h2>

      <ul>
        <% grouping.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
<% end %>
